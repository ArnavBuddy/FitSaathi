# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/fitsaathi
MONGODB_DB_NAME=fitsaathi

# Google Cloud
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us-central1
GOOGLE_API_KEY=
AGENT_ID=

# App Settings
SECRET_KEY=your-production-secret-key-here
ENVIRONMENT=production
MAX_UPLOAD_SIZE_MB=10
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://fitsaathi.vercel.app

# Virtual Try-On Settings
CATVTON_MODEL_PATH=
TRYON_OUTPUT_DIR=uploads/tryons
UPLOADS_USERS_DIR=uploads/users
UPLOADS_GARMENTS_DIR=uploads/garments
TRYON_TIMEOUT_SECONDS=300
USE_CUDA=false
# Colab GPU Acceleration
USE_COLAB=false
COLAB_API_URL=
COLAB_API_KEY=
